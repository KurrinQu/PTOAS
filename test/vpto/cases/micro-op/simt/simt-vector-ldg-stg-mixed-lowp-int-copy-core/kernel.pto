// Mixed low-precision / integer packed vector ldg/stg copy (roundtrip) test.
// 2 lanes: each lane loads a packed value from the input region and stores
// it to the output region.  No arithmetic — pure copy to verify that the
// load/store intrinsics (s16/b16 for 16-bit packed types) execute
// correctly on real SIM/NPU.
//
// Buffer layout (per buffer, 4 elements each):
//   input  region: [lane0=offset 0, lane1=offset 1]
//   output region: [lane0=offset 2, lane1=offset 3]

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @simt_vector_ldg_stg_mixed_lowp_int_copy_core_kernel(
      %hif8x2_buf: !pto.ptr<!pto.hif8x2, gm>,
      %i8x2_buf: !pto.ptr<vector<2xi8>, gm>,
      %fp8e4x2_buf: !pto.ptr<vector<2xf8E4M3FN>, gm>,
      %fp8e5x2_buf: !pto.ptr<vector<2xf8E5M2>, gm>
  ) attributes {pto.aicore} {
    %dim_z = arith.constant 1 : i32
    %dim_y = arith.constant 1 : i32
    %dim_x = arith.constant 2 : i32

    pto.simt_launch @simt_vector_ldg_stg_mixed_lowp_int_copy_core_body<<<%dim_x, %dim_y, %dim_z>>>(
      %hif8x2_buf, %i8x2_buf, %fp8e4x2_buf, %fp8e5x2_buf
    ) : (!pto.ptr<!pto.hif8x2, gm>, !pto.ptr<vector<2xi8>, gm>, !pto.ptr<vector<2xf8E4M3FN>, gm>, !pto.ptr<vector<2xf8E5M2>, gm>) -> ()

    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }

  func.func @simt_vector_ldg_stg_mixed_lowp_int_copy_core_body(
      %hif8x2_buf: !pto.ptr<!pto.hif8x2, gm>,
      %i8x2_buf: !pto.ptr<vector<2xi8>, gm>,
      %fp8e4x2_buf: !pto.ptr<vector<2xf8E4M3FN>, gm>,
      %fp8e5x2_buf: !pto.ptr<vector<2xf8E5M2>, gm>
  ) attributes {pto.simt_entry} {
    %c0 = arith.constant 0 : i32
    %c2 = arith.constant 2 : i32

    %laneid = pto.get_laneid : i32

    // output offset = laneid + 2  (output region starts at offset 2)
    %out_off = arith.addi %laneid, %c2 : i32

    %idx_in = arith.index_castui %laneid : i32 to index
    %idx_out = arith.index_castui %out_off : i32 to index

    // !pto.hif8x2 copy (16-bit load/store via s16/b16)
    %v_hif8x2 = pto.ldg %hif8x2_buf[%idx_in] : !pto.ptr<!pto.hif8x2, gm> -> !pto.hif8x2
    pto.stg %v_hif8x2, %hif8x2_buf[%idx_out] : !pto.ptr<!pto.hif8x2, gm>, !pto.hif8x2

    // vector<2xi8> copy (16-bit load/store via s16/b16)
    %v_i8x2 = pto.ldg %i8x2_buf[%idx_in] : !pto.ptr<vector<2xi8>, gm> -> vector<2xi8>
    pto.stg %v_i8x2, %i8x2_buf[%idx_out] : !pto.ptr<vector<2xi8>, gm>, vector<2xi8>

    // vector<2xf8E4M3FN> copy (16-bit load/store via s16/b16)
    %v_fp8e4 = pto.ldg %fp8e4x2_buf[%idx_in] : !pto.ptr<vector<2xf8E4M3FN>, gm> -> vector<2xf8E4M3FN>
    pto.stg %v_fp8e4, %fp8e4x2_buf[%idx_out] : !pto.ptr<vector<2xf8E4M3FN>, gm>, vector<2xf8E4M3FN>

    // vector<2xf8E5M2> copy (16-bit load/store via s16/b16)
    %v_fp8e5 = pto.ldg %fp8e5x2_buf[%idx_in] : !pto.ptr<vector<2xf8E5M2>, gm> -> vector<2xf8E5M2>
    pto.stg %v_fp8e5, %fp8e5x2_buf[%idx_out] : !pto.ptr<vector<2xf8E5M2>, gm>, vector<2xf8E5M2>

    return
  }
}
