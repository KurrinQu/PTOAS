// Template version of TADD vector implementation.
//
// Row/Col are extracted via intrinsic ops (pto.tile_rows, pto.tile_cols)
// instead of hardcoded constants, enabling a single implementation to
// serve all (rows, cols) combinations for a given dtype.
//
// Key differences from tadd_a5_static.pto:
//   - tile_buf shape uses ? (dynamic) instead of hardcoded values
//   - Loop bounds come from pto.tile_rows/pto.tile_cols intrinsics
//   - tile_buf_addr returns memref, vlds/vsts use memref[row][col] indexing
//   - Tail mask via pto.plt_b32 for cols not divisible by vector_width
//   - pto.tile_function = "pto.tadd" for lowering lookup and VF fusion
//   - pto.access attributes on parameters for VF fusion data-flow analysis
//
// Parameter order matches pto.tadd ODS definition: ins(src0, src1) outs(dst)
//
// The Tile→Vector lowering pass will:
//   1. Clone this template for each unique (rows, cols) combination
//   2. Fill in the concrete tile_buf type on the function signature
//   3. Fold intrinsics to arith.constant (e.g. pto.tile_rows → constant 16)
//      Dynamic fields (e.g. v_row=?) remain as intrinsics, resolved after inline
//   4. Inline the specialized function body at the call site
//
// TODO: add RUN line once intrinsics are implemented

module {
  // Parameter order: src0, src1, dst (matching pto.tadd ins/outs order)
  func.func @TADD_f32(
      %src0: !pto.tile_buf<loc=vec, dtype=f32, rows=?, cols=?, v_row=?, v_col=?,
                           blayout=row_major, slayout=none_box, fractal=512, pad=0>
             {pto.access = "read"},
      %src1: !pto.tile_buf<loc=vec, dtype=f32, rows=?, cols=?, v_row=?, v_col=?,
                           blayout=row_major, slayout=none_box, fractal=512, pad=0>
             {pto.access = "read"},
      %dst:  !pto.tile_buf<loc=vec, dtype=f32, rows=?, cols=?, v_row=?, v_col=?,
                           blayout=row_major, slayout=none_box, fractal=512, pad=0>
             {pto.access = "write"})
      attributes { pto.tile_function = "pto.tadd" } {

    // --- extract memref (rows x cols x dtype) ---
    %mSrc0 = pto.tile_buf_addr %src0 : !pto.tile_buf<loc=vec, dtype=f32, rows=?, cols=?, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0> -> memref<?x?xf32, strided<[?, 1]>, #pto.address_space<vec>>
    %mSrc1 = pto.tile_buf_addr %src1 : !pto.tile_buf<loc=vec, dtype=f32, rows=?, cols=?, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0> -> memref<?x?xf32, strided<[?, 1]>, #pto.address_space<vec>>
    %mDst  = pto.tile_buf_addr %dst  : !pto.tile_buf<loc=vec, dtype=f32, rows=?, cols=?, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0> -> memref<?x?xf32, strided<[?, 1]>, #pto.address_space<vec>>

    // --- extract shape via intrinsic placeholders ---
    // After specialization, these fold to arith.constant.
    // Dynamic fields (e.g. v_row=?) remain as intrinsics, resolved after inline.
    %v_rows = pto.tile_valid_rows %src0 : !pto.tile_buf<loc=vec, dtype=f32, rows=?, cols=?, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0> -> index
    %v_cols = pto.tile_valid_cols %src0 : !pto.tile_buf<loc=vec, dtype=f32, rows=?, cols=?, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0> -> index
    %v_cols_i32 = arith.index_cast %v_cols : index to i32  // plt_b32 requires i32

    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c64 = arith.constant 64 : index   // vector_width for f32 = 256B / 4B = 64

    pto.vecscope {
      scf.for %arg0 = %c0 to %v_rows step %c1 {
        scf.for %arg1 = %c0 to %v_cols step %c64 iter_args(%remain = %v_cols_i32) -> (i32) {
          // Tail mask: remain starts at valid_cols, decremented by vector_width each iteration.
          // When remain < 64, plt_b32 generates partial mask for tail elements.
          %mask, %next_remain = pto.plt_b32 %remain : i32 -> !pto.mask, i32

          // memref[row, col] indexing: tile_buf_addr returns memref<?x?xf32, ...>,
          // vlds/vsts use standard memref 2D indexing.
          %va = pto.vlds %mSrc0[%arg0, %arg1] : memref<?x?xf32, strided<[?, 1]>, #pto.address_space<vec>> -> !pto.vreg<64xf32>
          %vb = pto.vlds %mSrc1[%arg0, %arg1] : memref<?x?xf32, strided<[?, 1]>, #pto.address_space<vec>> -> !pto.vreg<64xf32>
          %vc = pto.vadd %va, %vb, %mask : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask -> !pto.vreg<64xf32>
          pto.vsts %vc, %mDst[%arg0, %arg1], %mask : !pto.vreg<64xf32>, memref<?x?xf32, strided<[?, 1]>, #pto.address_space<vec>>, !pto.mask
          scf.yield %next_remain : i32
        }
      }
    }
    return
  }
}
