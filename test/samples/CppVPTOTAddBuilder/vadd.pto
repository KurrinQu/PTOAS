module attributes {pto.target_arch = "a5"} {
  func.func @tadd_tile_lowered_to_vecscope(%arg0: !pto.ptr<f32, gm>, %arg1: !pto.ptr<f32, gm>, %arg2: !pto.ptr<f32, gm>) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c8 = arith.constant 8 : index
    %c64 = arith.constant 64 : index
    %c128 = arith.constant 128 : index
    %0 = pto.make_tensor_view %arg0, shape = [%c8, %c128], strides = [%c128, %c1] : !pto.tensor_view<?x?xf32>
    %1 = pto.make_tensor_view %arg1, shape = [%c8, %c128], strides = [%c128, %c1] : !pto.tensor_view<?x?xf32>
    %2 = pto.make_tensor_view %arg2, shape = [%c8, %c128], strides = [%c128, %c1] : !pto.tensor_view<?x?xf32>
    %3 = pto.partition_view %0, offsets = [%c0, %c0], sizes = [%c8, %c128] : !pto.tensor_view<?x?xf32>
    %4 = pto.partition_view %1, offsets = [%c0, %c0], sizes = [%c8, %c128] : !pto.tensor_view<?x?xf32>
    %5 = pto.partition_view %2, offsets = [%c0, %c0], sizes = [%c8, %c128] : !pto.tensor_view<?x?xf32>
    %6 = pto.alloc_tile : !pto.tile_buf<vec, 8x128xf32>
    %7 = pto.alloc_tile : !pto.tile_buf<vec, 8x128xf32>
    %8 = pto.alloc_tile : !pto.tile_buf<vec, 8x128xf32>
    pto.tload ins(%3 : !pto.partition_tensor_view<8x128xf32>) outs(%6 : !pto.tile_buf<vec, 8x128xf32>)
    pto.tload ins(%4 : !pto.partition_tensor_view<8x128xf32>) outs(%7 : !pto.tile_buf<vec, 8x128xf32>)
    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.vecscope {
      %9 = pto.tile_buf_addr %6 : !pto.tile_buf<vec, 8x128xf32> -> !pto.ptr<f32, ub>
      %10 = pto.tile_buf_addr %7 : !pto.tile_buf<vec, 8x128xf32> -> !pto.ptr<f32, ub>
      %11 = pto.tile_buf_addr %8 : !pto.tile_buf<vec, 8x128xf32> -> !pto.ptr<f32, ub>
      %12 = pto.tile_valid_rows %6 : !pto.tile_buf<vec, 8x128xf32> -> index
      %13 = pto.tile_valid_cols %6 : !pto.tile_buf<vec, 8x128xf32> -> index
      %14 = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>
      scf.for %arg3 = %c0 to %12 step %c1 {
        %15 = arith.muli %arg3, %c128 : index
        scf.for %arg4 = %c0 to %13 step %c64 {
          %16 = arith.addi %15, %arg4 : index
          %17 = pto.vlds %9[%16] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
          %18 = pto.vlds %10[%16] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
          %19 = pto.vadd %17, %18, %14 : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>
          pto.vsts %19, %11[%16], %14 : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>
        }
      }
    }
    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.tstore ins(%8 : !pto.tile_buf<vec, 8x128xf32>) outs(%5 : !pto.partition_tensor_view<8x128xf32>)
    return
  }
}

