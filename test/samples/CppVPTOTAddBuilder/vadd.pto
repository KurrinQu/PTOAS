module attributes {pto.target_arch = "a5"} {
  func.func @tadd_tile_lowered_to_vecscope(%arg0: !pto.ptr<f32, gm>, %arg1: !pto.ptr<f32, gm>, %arg2: !pto.ptr<f32, gm>) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c16 = arith.constant 16 : index
    %c64 = arith.constant 64 : index
    %c1024 = arith.constant 1024 : index
    %c0_i64 = arith.constant 0 : i64
    %c4096_i64 = arith.constant 4096 : i64
    %c8192_i64 = arith.constant 8192 : i64
    %0 = pto.make_tensor_view %arg0, shape = [%c1, %c1, %c1, %c16, %c64], strides = [%c1024, %c1024, %c1024, %c64, %c1] : !pto.tensor_view<?x?x?x?x?xf32>
    %1 = pto.make_tensor_view %arg1, shape = [%c1, %c1, %c1, %c16, %c64], strides = [%c1024, %c1024, %c1024, %c64, %c1] : !pto.tensor_view<?x?x?x?x?xf32>
    %2 = pto.make_tensor_view %arg2, shape = [%c1, %c1, %c1, %c16, %c64], strides = [%c1024, %c1024, %c1024, %c64, %c1] : !pto.tensor_view<?x?x?x?x?xf32>
    %3 = pto.partition_view %0, offsets = [%c0, %c0, %c0, %c0, %c0], sizes = [%c1, %c1, %c1, %c16, %c64] : !pto.tensor_view<?x?x?x?x?xf32>
    %4 = pto.partition_view %1, offsets = [%c0, %c0, %c0, %c0, %c0], sizes = [%c1, %c1, %c1, %c16, %c64] : !pto.tensor_view<?x?x?x?x?xf32>
    %5 = pto.partition_view %2, offsets = [%c0, %c0, %c0, %c0, %c0], sizes = [%c1, %c1, %c1, %c16, %c64] : !pto.tensor_view<?x?x?x?x?xf32>
    %6 = pto.alloc_tile addr = %c0_i64 : !pto.tile_buf<vec, 16x64xf32>
    %7 = pto.alloc_tile addr = %c4096_i64 : !pto.tile_buf<vec, 16x64xf32>
    %8 = pto.alloc_tile addr = %c8192_i64 : !pto.tile_buf<vec, 16x64xf32>
    pto.tload ins(%3 : !pto.partition_tensor_view<1x1x1x16x64xf32>) outs(%6 : !pto.tile_buf<vec, 16x64xf32>)
    pto.tload ins(%4 : !pto.partition_tensor_view<1x1x1x16x64xf32>) outs(%7 : !pto.tile_buf<vec, 16x64xf32>)
    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.vecscope {
      %9 = pto.tile_buf_addr %6 : !pto.tile_buf<vec, 16x64xf32> -> !pto.ptr<f32, ub>
      %10 = pto.tile_buf_addr %7 : !pto.tile_buf<vec, 16x64xf32> -> !pto.ptr<f32, ub>
      %11 = pto.tile_buf_addr %8 : !pto.tile_buf<vec, 16x64xf32> -> !pto.ptr<f32, ub>
      %12 = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>
      scf.for %arg3 = %c0 to %c16 step %c1 {
        %13 = arith.muli %arg3, %c64 : index
        scf.for %arg4 = %c0 to %c64 step %c64 {
          %14 = arith.addi %13, %arg4 : index
          %15 = pto.vlds %9[%14] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
          %16 = pto.vlds %10[%14] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
          %17 = pto.vadd %15, %16, %12 : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>
          pto.vsts %17, %11[%14], %12 : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>
        }
      }
    }
    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.tstore ins(%8 : !pto.tile_buf<vec, 16x64xf32>) outs(%5 : !pto.partition_tensor_view<1x1x1x16x64xf32>)
    return
  }
}
