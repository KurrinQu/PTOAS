module {
  func.func @frontend_pipe_v0_roundtrip_cube() attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %buf0 = arith.constant 0 : i32
    %buf1 = arith.constant 1024 : i32
    pto.aic_initialize_pipe {dir_mask = 3, slot_size = 1024}
      (c2v_consumer_buf = %buf0 : i32,
       v2c_consumer_buf = %buf1 : i32)
    %acc_tile = pto.alloc_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>
    pto.tpush_to_aiv(%acc_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>) {split = 0}
    %mat_tile = pto.tpop_from_aiv {split = 0} -> !pto.tile_buf<loc=mat, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    pto.tfree_from_aiv {split = 0}
    return
  }

  func.func @frontend_pipe_v0_roundtrip() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %buf0 = arith.constant 0 : i32
    %buf1 = arith.constant 1024 : i32
    pto.aiv_initialize_pipe {dir_mask = 3, slot_size = 1024}
      (c2v_consumer_buf = %buf0 : i32,
       v2c_consumer_buf = %buf1 : i32)
    %vec_tile = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tpush_to_aic(%vec_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>) {split = 0}
    %recv_tile = pto.tpop_from_aic {split = 0} -> !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tfree_from_aic {split = 0}
    pto.tprint ins(%recv_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}
